# Sandbox configuration
SANDBOX_TYPE=local
LOCAL_SANDBOX_ROOT_DIR=/Users/agent/sandboxes

# LLM
ANTHROPIC_API_KEY=

# GitHub App (preferred over PAT)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# Or use a personal access token
GITHUB_TOKEN=

# Repo defaults
DEFAULT_REPO_OWNER=AresFitness
DEFAULT_REPO_NAME=RedefinedFitness
ALLOWED_GITHUB_ORGS=AresFitness

# Slack integration
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_BOT_USER_ID=
SLACK_REPO_OWNER=AresFitness
SLACK_REPO_NAME=RedefinedFitness

# Linear integration
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=

# GitHub webhook
GITHUB_WEBHOOK_SECRET=

# Observability
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=amp-swe-agent

# AWS (needed for backend `pnpm local up` — generates AWS exports)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# === E2E Testing (Maestro) ===
AMP_DEV_USERNAME=
AMP_DEV_PASSWORD=
AMP_APP_BUNDLE_ID=io.ampinteractive.amp.dev
